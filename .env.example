# Environment Variables

# Google Gemini API Key (server-side only; set in Vercel)
GEMINI_API_KEY=your_api_key_here

# Comma-separated list of origins allowed to call /api/gemini from a browser.
# Optional: VITE_SITE_URL and the Vercel deployment URL are allowed automatically.
# Example: https://www.escp-students-for-finance.com,https://escp-finance.vercel.app
ALLOWED_ORIGINS=
